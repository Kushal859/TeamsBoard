			"name": "Auth",
			"item": [
				{
					"name": "1. Register — Success (201)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test('Response has required fields', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('username');",
									"    pm.expect(json).to.have.property('company_name');",
									"    pm.expect(json).to.have.property('api_key');",
									"    pm.expect(json).to.have.property('access');",
									"});",
									"pm.test('Username matches request', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.username).to.eql('testcorp');",
									"});",
									"pm.test('Company name matches request', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.company_name).to.eql('Test Corp');",
									"});",
									"// Save token for later use",
									"var json = pm.response.json();",
									"pm.collectionVariables.set('access_token', json.access);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testcorp\",\n    \"password\": \"securepass123\",\n    \"company_name\": \"Test Corp\",\n    \"email\": \"dev@testcorp.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register/",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register", ""]
						}
					}
				},
