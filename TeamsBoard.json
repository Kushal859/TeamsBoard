				{
					"name": "11. Usage Summary — Admin Role (200)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has total_queries', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('total_queries');",
									"    pm.expect(json.total_queries).to.be.a('number');",
									"});",
									"pm.test('Response has active_companies', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('active_companies');",
									"    pm.expect(json.active_companies).to.be.a('number');",
									"});",
									"pm.test('Response has top_search_terms as array', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('top_search_terms');",
									"    pm.expect(json.top_search_terms).to.be.an('array');",
									"});",
									"pm.test('Top search terms have search_term and count', function () {",
									"    var json = pm.response.json();",
									"    if (json.top_search_terms.length > 0) {",
									"        var t = json.top_search_terms[0];",
									"        pm.expect(t).to.have.property('search_term');",
									"        pm.expect(t).to.have.property('count');",
									"    }",
									"});"
								],
