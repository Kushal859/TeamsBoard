		{
			"name": "Knowledge Base",
			"item": [
				{
					"name": "5. KB Query — Success with Results (200)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has search, count, and results', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('search');",
									"    pm.expect(json).to.have.property('count');",
									"    pm.expect(json).to.have.property('results');",
									"});",
									"pm.test('Count matches results array length', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.count).to.eql(json.results.length);",
									"});",
									"pm.test('Each result has id, question, answer, category', function () {",
									"    var json = pm.response.json();",
									"    if (json.results.length > 0) {",
									"        var r = json.results[0];",
									"        pm.expect(r).to.have.property('id');",
									"        pm.expect(r).to.have.property('question');",
									"        pm.expect(r).to.have.property('answer');",
									"        pm.expect(r).to.have.property('category');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
